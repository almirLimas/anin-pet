# ──────────────────────────────────────────────
#  Banco de dados (PostgreSQL)
#  Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/aninpet?schema=public"

# ──────────────────────────────────────────────
#  Autenticação JWT
#  Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ──────────────────────────────────────────────
JWT_SECRET="troque-por-uma-string-aleatoria-de-64-chars"
JWT_EXPIRES_IN="7d"

# ──────────────────────────────────────────────
#  Servidor
# ──────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# URL pública da API (usada nos callbacks do MercadoPago)
BASE_URL="https://api.seudominio.com.br"

# ──────────────────────────────────────────────
#  CORS / Frontend
# ──────────────────────────────────────────────
FRONTEND_URL="https://seudominio.com.br"

# ──────────────────────────────────────────────
#  MercadoPago
#  Obtenha em: https://www.mercadopago.com.br/developers/panel
# ──────────────────────────────────────────────
MP_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# MP_WEBHOOK_SECRET="chave-secreta-do-webhook-mp"

# ──────────────────────────────────────────────
#  E-mail (SMTP para recuperação de senha)
#  Opção gratuita recomendada: Resend (https://resend.com) — 3.000 e-mails/mês
#  Alternativa: Gmail (use senha de app, não a senha normal)
# ──────────────────────────────────────────────
EMAIL_HOST="smtp.resend.com"
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER="resend"
EMAIL_PASS="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="noreply@aninpet.com.br"

# ──────────────────────────────────────────────
#  WhatsApp
#  Modos: simulacao | baileys | zapi | evolution
# ──────────────────────────────────────────────
WHATSAPP_MODE="simulacao"

# Baileys — gratuito, usa seu próprio WhatsApp (escaneia QR code no terminal)
# WHATSAPP_MODE=baileys

# Z-API (pago, https://z-api.io)
# WHATSAPP_MODE=zapi
# ZAPI_INSTANCE_ID=SEU_INSTANCE_ID
# ZAPI_TOKEN=SEU_TOKEN
# ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN

# Evolution API (self-hosted com Docker)
# WHATSAPP_MODE=evolution
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=SUA_CHAVE
# EVOLUTION_INSTANCE=meu-pet
