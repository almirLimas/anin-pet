// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Perfil {
  admin
  staff
}

enum StatusUsuario {
  ativo
  inativo
}

enum Plano {
  basico
  plus
  profissional
  completo
}

enum AssinaturaStatus {
  trial
  pendente
  ativa
  suspensa
  cancelada
}

// ── Tenant (petshop) ─────────────────────────────────────────────────────────

model Tenant {
  id               String           @id @default(cuid())
  nome             String
  plano            Plano            @default(basico)
  status           StatusUsuario    @default(ativo)
  assinaturaStatus     AssinaturaStatus @default(trial)
  trialExpiraEm        DateTime?
  avisoTrial3dEnviadoEm DateTime?
  avisoTrial1dEnviadoEm DateTime?
  mpAssinaturaId   String?
  mpPagamentoId    String?
  metaMensal       Decimal?         @db.Decimal(10, 2)
  taxaBusca        Decimal?         @db.Decimal(10, 2)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  usuarios      Usuario[]
  clientes      Cliente[]
  pets          Pet[]
  servicos      Servico[]
  agendamentos  Agendamento[]
  lancamentos   Lancamento[]
  produtos      Produto[]
  movimentacoes Movimentacao[]
  vacinas       Vacina[]
  avaliacoes    AvaliacaoCliente[]
  vendas        Venda[]
  itensVenda    ItemVenda[]
}

// ── Usuários (auth) ──────────────────────────────────────────────────────────

model Usuario {
  id                 String        @id @default(cuid())
  nomeCompleto       String
  email              String        @unique
  cpf                String?       @unique
  telefone           String?
  senhaHash          String
  perfil             Perfil        @default(admin)
  status             StatusUsuario @default(ativo)
  tenantId           String
  resetToken         String?
  resetTokenExpiraEm DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ── Clientes ─────────────────────────────────────────────────────────────────

enum StatusCliente {
  Ativo
  Inativo
}

model Cliente {
  id                 String        @id @default(cuid())
  codigo             Int           @default(autoincrement())
  nome               String
  cpf                String?
  telefonePrincipal  String
  telefoneSecundario String?
  email              String?
  cep                String?
  rua                String?
  numero             String?
  complemento        String?
  bairro             String?
  cidade             String?
  estado             String?
  dataNascimento     String?
  comoConheceu       String?
  observacoes        String?
  mensalista              Boolean       @default(false)
  valorMensal             Decimal?      @db.Decimal(10, 2)
  diaVencimento           Int?
  ultimaMensalidadePaga   DateTime?
  status             StatusCliente @default(Ativo)
  tenantId           String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  pets         Pet[]
  agendamentos Agendamento[]
  avaliacoes   AvaliacaoCliente[]
  vendas       Venda[]

  @@unique([tenantId, cpf])
  @@unique([tenantId, codigo])
}

// ── Pets ─────────────────────────────────────────────────────────────────────

model Pet {
  id             String   @id @default(cuid())
  nome           String
  especie        String?
  raca           String?
  porte          String?
  sexo           String?
  dataNascimento String?
  cor            String?
  peso           String?
  alergias       String?
  observacoes    String?
  clienteId      String
  tenantId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  cliente      Cliente       @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  agendamentos Agendamento[]
  vacinas      Vacina[]
}

// ── Serviços ──────────────────────────────────────────────────────────────────

enum CategoriaServico {
  Banho
  Tosa
  Consulta
  Vacina
  Internacao
  Cirurgia
  Exame
  Outro
}

enum PorteServico {
  Pequeno
  Medio
  Grande
  Todos
}

model Servico {
  id             String           @id @default(cuid())
  nome           String
  categoria      CategoriaServico
  porte          PorteServico     @default(Todos)
  duracaoMinutos Int?
  preco          Decimal          @db.Decimal(10, 2)
  descricao      String?
  ativo          Boolean          @default(true)
  tenantId       String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant       Tenant                @relation(fields: [tenantId], references: [id])
  agendamentos AgendamentoServico[]
  itensVenda   ItemVenda[]
}

// ── Agenda ───────────────────────────────────────────────────────────────────

enum StatusAgendamento {
  Agendado
  Confirmado
  EmAtendimento
  Concluido
  Cancelado
  NaoCompareceu
}

enum ModalidadeAgendamento {
  ClienteTraz
  PetshopBusca
}

model Agendamento {
  id          String                 @id @default(cuid())
  dataHora    DateTime
  observacoes String?
  status      StatusAgendamento      @default(Agendado)
  modalidade  ModalidadeAgendamento  @default(ClienteTraz)
  taxaBusca   Decimal?               @db.Decimal(10, 2)
  clienteId   String
  petId       String
  tenantId    String
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  tenant      Tenant                @relation(fields: [tenantId], references: [id])
  cliente     Cliente               @relation(fields: [clienteId], references: [id])
  pet         Pet                   @relation(fields: [petId], references: [id])
  servicos    AgendamentoServico[]
  lancamentos Lancamento[]
  avaliacao   AvaliacaoCliente?
}

model AgendamentoServico {
  agendamentoId String
  servicoId     String

  agendamento Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  servico     Servico     @relation(fields: [servicoId], references: [id])

  @@id([agendamentoId, servicoId])
}

// ── Financeiro ───────────────────────────────────────────────────────────────────────

enum TipoLancamento {
  Receita
  Despesa
}

enum CategoriaLancamento {
  Servico
  Produto
  Consulta
  Material
  Manutencao
  Outro
}

model Lancamento {
  id            String              @id @default(cuid())
  tipo          TipoLancamento
  valor         Decimal             @db.Decimal(10, 2)
  descricao     String
  categoria     CategoriaLancamento @default(Outro)
  data          DateTime            @default(now())
  agendamentoId String?
  tenantId      String
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  agendamento Agendamento? @relation(fields: [agendamentoId], references: [id])
}

// ── Avaliações de Satisfação ─────────────────────────────────────────────────

model AvaliacaoCliente {
  id            String    @id @default(cuid())
  nota          Int       // 1 a 5
  token         String    @unique
  respondidaEm  DateTime?
  agendamentoId String    @unique
  clienteId     String
  tenantId      String
  createdAt     DateTime  @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  agendamento Agendamento @relation(fields: [agendamentoId], references: [id], onDelete: Cascade)
  cliente     Cliente     @relation(fields: [clienteId], references: [id])
}

// ── Estoque ──────────────────────────────────────────────────────────────────

enum CategoriaEstoque {
  Medicamento
  Alimento
  Acessorio
  Higiene
  Vacina
  Outro
}

model Produto {
  id              String           @id @default(cuid())
  nome            String
  categoria       CategoriaEstoque
  unidade         String?
  codigoBarras    String?
  marca           String?
  quantidadeAtual Int              @default(0)
  estoqueMinimo   Int              @default(0)
  precoCompra     Decimal          @db.Decimal(10, 2)
  precoVenda      Decimal?         @db.Decimal(10, 2)
  descricao       String?
  ativo           Boolean          @default(true)
  tenantId        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  movimentacoes Movimentacao[]
  itensVenda    ItemVenda[]
}

enum TipoMovimentacao {
  Entrada
  Saida
}

model Movimentacao {
  id            String           @id @default(cuid())
  tipo          TipoMovimentacao
  quantidade    Int
  precoUnitario Decimal?         @db.Decimal(10, 2)
  motivo        String?
  observacoes   String?
  usuarioId     String?
  produtoId     String
  tenantId      String
  createdAt     DateTime         @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)
}

// ── Vacinas ──────────────────────────────────────────────────────────────────

enum StatusVacina {
  Aplicada
  Pendente
  Atrasada
}

model Vacina {
  id            String       @id @default(cuid())
  nome          String
  fabricante    String?
  lote          String?
  dataAplicacao DateTime
  dataReforco   DateTime?
  status        StatusVacina @default(Aplicada)
  observacoes   String?
  petId         String
  tenantId      String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  pet    Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)
}

// ── PDV (Ponto de Venda) ─────────────────────────────────────────────────────

enum FormaPagamento {
  Dinheiro
  Cartao
  Pix
  Fiado
  Outro
}

enum StatusVenda {
  Concluida
  Cancelada
}

enum TipoItemVenda {
  Produto
  Servico
}

model Venda {
  id             String         @id @default(cuid())
  numero         Int
  status         StatusVenda    @default(Concluida)
  formaPagamento FormaPagamento
  valorTotal     Decimal        @db.Decimal(10, 2)
  desconto       Decimal?       @db.Decimal(10, 2)
  valorPago      Decimal?       @db.Decimal(10, 2)
  troco          Decimal?       @db.Decimal(10, 2)
  observacoes    String?
  clienteId      String?
  tenantId       String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant  Tenant     @relation(fields: [tenantId], references: [id])
  cliente Cliente?   @relation(fields: [clienteId], references: [id])
  itens   ItemVenda[]

  @@unique([tenantId, numero])
}

model ItemVenda {
  id            String       @id @default(cuid())
  tipo          TipoItemVenda
  nome          String
  quantidade    Int
  precoUnitario Decimal      @db.Decimal(10, 2)
  subtotal      Decimal      @db.Decimal(10, 2)
  produtoId     String?
  servicoId     String?
  vendaId       String
  tenantId      String

  venda   Venda    @relation(fields: [vendaId], references: [id], onDelete: Cascade)
  produto Produto? @relation(fields: [produtoId], references: [id])
  servico Servico? @relation(fields: [servicoId], references: [id])
  tenant  Tenant   @relation(fields: [tenantId], references: [id])
}
